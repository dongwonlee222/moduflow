{
  "schema": "moduflow.config.v1",
  "project_name": "ModuFlow",
  "git": {
    "required": true,
    "github_sync": "optional",
    "issue_source": "git-files",
    "remote": "https://github.com/dongwonlee222/moduflow",
    "identity": {
      "mode": "remote",
      "provider": "github",
      "canonical_repository": "github.com/dongwonlee222/moduflow",
      "remote_name_hint": "origin",
      "base_branch": "main",
      "lifecycle": "active"
    }
  },
  "paths": {
    "issues": "issues",
    "specs": "specs",
    "workspace": "workspace",
    "knowledge": "knowledge"
  },
  "commands": {
    "start": "product:start",
    "status": "product:status",
    "doctor": "product:doctor"
  }
}
